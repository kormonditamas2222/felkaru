<Window x:Class="gambling.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gambling"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="1200">
    <Grid>
        <Canvas x:Name="myCanvas" Height="800" Width="1200">
            <Rectangle Canvas.Left="250" Canvas.Top="100" Height="600" Stroke="Black" Width="200"/>
            <Rectangle Canvas.Left="500" Canvas.Top="100" Height="600" Stroke="Black" Width="200"/>
            <Rectangle Canvas.Left="750" Canvas.Top="100" Height="600" Stroke="Black" Width="200"/>
            <Rectangle Canvas.Top="400" Width="1200" Height="5" Fill="Red"/>
            <Button Content="Pörgetés" FontSize="36" Canvas.Left="700" Canvas.Top="700"/>
            <Label Content="Kreditek:" FontSize="30" Width="285" Canvas.Left="400" Canvas.Top="700"></Label>
        </Canvas>

    </Grid>
</Window>

<Window x:Class="gambling.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gambling"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="1200">
    <Grid>
        <Canvas x:Name="myCanvas" Height="800" Width="1200">
            <Label x:Name="lb_eredmeny" Canvas.Top="30" Canvas.Left="580" FontSize="24"/>

            <Border Canvas.Left="250" Canvas.Top="100" Width="200" Height="600" BorderBrush="Black" BorderThickness="1" ClipToBounds="True">
                <StackPanel x:Name="spReel1" RenderTransformOrigin="0.5,0.0">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                </StackPanel>
            </Border>

            <Border Canvas.Left="500" Canvas.Top="100" Width="200" Height="600" BorderBrush="Black" BorderThickness="1" ClipToBounds="True">
                <StackPanel x:Name="spReel2" RenderTransformOrigin="0.5,0.0">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                </StackPanel>
            </Border>

            <Border Canvas.Left="750" Canvas.Top="100" Width="200" Height="600" BorderBrush="Black" BorderThickness="1" ClipToBounds="True">
                <StackPanel x:Name="spReel3" RenderTransformOrigin="0.5,0.0">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                    <Image Height="200" Width="200" Stretch="UniformToFill"/>
                </StackPanel>
            </Border>

            <Rectangle Canvas.Top="400" Width="1200" Height="5" Fill="Red"/>
            <Button x:Name="btnSpin" Content="Pörgetés" FontSize="36" Canvas.Left="700" Canvas.Top="700" Click="Button_Click"/>
            <Label x:Name="lb_kredit" Content="Kreditek:" FontSize="30" Width="285" Canvas.Left="400" Canvas.Top="700"></Label>
        </Canvas>
    </Grid>
</Window>
